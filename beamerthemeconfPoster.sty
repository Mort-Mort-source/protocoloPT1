\ProvidesPackage{beamerthemeConfPoster}
\RequirePackage[utf8]{inputenc}
\RequirePackage{tikz}
\usetikzlibrary{arrows,backgrounds}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}
\usepackage{exscale}
\RequirePackage{textcomp}
\RequirePackage{amsmath,amssymb}
\usefonttheme{professionalfonts}
\RequirePackage{ragged2e}

% Colores UAM
\definecolor{uamorange}{RGB}{255, 102, 0}
\definecolor{uamgray}{RGB}{80, 80, 80}
\definecolor{uamlightgray}{RGB}{240, 240, 240}

% Definir colores del tema
\setbeamercolor{palette primary}{fg=black, bg=white}
\setbeamercolor{palette secondary}{fg=black, bg=white}
\setbeamercolor{palette tertiary}{bg=uamorange, fg=white}
\setbeamercolor{palette quaternary}{fg=black, bg=white}
\setbeamercolor{structure}{fg=uamorange}
\setbeamercolor{titlelike}{bg=uamorange, fg=white}
\setbeamercolor{frametitle}{bg=uamorange, fg=white}
\setbeamercolor{cboxb}{fg=black, bg=uamorange}
\setbeamercolor{cboxr}{fg=black, bg=red}

% Items
\setbeamercolor{item}{fg=uamorange}
\setbeamercolor{item projected}{fg=white, bg=uamorange}

% Bloques
\setbeamercolor{block title}{fg=uamorange, bg=white}
\setbeamercolor{block body}{fg=black, bg=white}

% Bloques alert (con marco)
\setbeamercolor{block alerted title}{fg=white, bg=uamorange}
\setbeamercolor{block alerted body}{fg=black, bg=white}

% Fuentes
\setbeamerfont{section in head/foot}{series=\bfseries}
\setbeamerfont{block title}{series=\bfseries}
\setbeamerfont{block alerted title}{series=\bfseries}
\setbeamerfont{frametitle}{series=\bfseries, size=\Large}
\setbeamerfont{block body}{series=\rmfamily}

% Plantillas
\setbeamertemplate{title page}[default][colsep=-4bp,rounded=true]
\setbeamertemplate{sections/subsections in toc}[square]
\setbeamertemplate{items}[circle]
\setbeamertemplate{blocks}[width=0.0]
\beamertemplatenavigationsymbolsempty

% Bibliografía
\setbeamertemplate{bibliography item}[text]
\setbeamercolor{bibliography item}{fg=black,bg=white}
\setbeamercolor{bibliography entry author}{fg=black,bg=white}
\setbeamercolor{bibliography item}{fg=black,bg=white}

% Longitudes
\newlength{\inboxwd}
\newlength{\iinboxwd}
\newlength{\inboxrule}
\makeatletter
\makeatother

%==============================================================================
% Headline (título en negro)
%==============================================================================
\setbeamertemplate{headline}{
 \leavevmode
  \begin{columns}
   \begin{column}{\linewidth}
    \vskip0cm
    \centering
    \usebeamercolor{title in headline}{\color{black}\Huge{\textbf{\inserttitle}}\\[0.3ex]}  % <-- título en negro
    \usebeamercolor{author in headline}{\color{uamgray}\Large{\insertauthor}\\[0.2ex]}
    \usebeamercolor{institute in headline}{\color{uamgray}\large{\insertinstitute}\\[0.5ex]}
   \end{column}
   \vspace{0cm}
  \end{columns}
 \vspace{0.1in}
 \hspace{0.3in}\begin{beamercolorbox}[wd=47in,colsep=0.15cm]{cboxb}\end{beamercolorbox}
 \vspace{0.0in}
}

%==============================================================================
% Footline (pie con logos y asesores)
%==============================================================================
\setbeamertemplate{footline}{
\leavevmode
\hspace{0.5in}\begin{beamercolorbox}[wd=47in,colsep=0.15cm]{cboxb}\end{beamercolorbox}
\vspace{0.3cm}
\begin{columns}[b]
  \begin{column}{0.3\linewidth}
    \centering
    \vspace{0.5cm}
    \includegraphics[scale=.99]{imagenes/image5.png}
  \end{column}
  \begin{column}{0.4\linewidth}    
    \centering
    \vspace{0.5cm}
    \usebeamercolor{author in footline}
    \color{uamgray}\Large{\textbf{Asesores:}}\\[0.1ex]
    \color{uamgray}\large{Dra. Betzabet }\\[0.1ex]
    \color{uamgray}\large{Dr. Guillermo Monroy Rodríguez}
  \end{column}
  \begin{column}{0.3\linewidth}
    \centering
    \vspace{0.5cm}
    \includegraphics[scale=0.3]{imagenes/image1.png}
  \end{column}
\end{columns}
}

%==============================================================================
% Definición de bloques (con bordes redondeados y tcolorbox)
% Espacios reducidos para que quepa todo
%==============================================================================
\setbeamertemplate{block begin}
{
  \par\vskip-0.6cm
  \begin{beamercolorbox}[rounded=true,sep=3pt,shadow=false,center,wd=\textwidth]{block title}
    \usebeamerfont{block title}\large\insertblocktitle
  \end{beamercolorbox}
  {\parskip0pt\par}
  \usebeamerfont{block body}
  \vskip-1.0cm
  \begin{tcolorbox}[colframe=white,colback=white,arc=5pt,
    top=3pt,bottom=3pt,left=8pt,right=8pt]
  \vspace*{0pt}
  \justifying
  \setlength{\parskip}{2pt}  % Reducir separación entre párrafos
}

\setbeamertemplate{block end}
{
  \end{tcolorbox}
  \vskip0.3cm  % Reducido de 0.7cm
}

% Bloques alert (con marco naranja) - se mantienen igual
\setbeamertemplate{block alerted begin}
{
  \par\vskip\medskipamount
  \begin{beamercolorbox}[sep=0ex,rounded=true,center,dp={2ex}]{block alerted title}
    \vskip0.01cm
    \usebeamerfont{block title}\large\insertblocktitle
  \end{beamercolorbox}
  {\parskip0pt\par}
  \usebeamerfont{block body}
  \vskip-0.8cm
  \begin{beamercolorbox}[sep=0.5cm, rounded=true,center]{block alerted title}
  \setlength{\inboxwd}{\linewidth}
  \addtolength{\inboxwd}{-1cm}
  \begin{beamercolorbox}[rounded=true,wd={\inboxwd},center]{block alerted body}
  \setlength{\iinboxwd}{\inboxwd}
  \setlength{\inboxrule}{\inboxwd}
  \addtolength{\iinboxwd}{-0.5cm}
  \addtolength{\inboxrule}{0.5cm}
  \begin{center}
  \begin{minipage}{\iinboxwd}
  \justifying
}

\setbeamertemplate{block alerted end}
{
  \end{minipage}
  \end{center}
  \end{beamercolorbox}
  \end{beamercolorbox}
  \vskip\smallskipamount
}